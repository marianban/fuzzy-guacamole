{
  "name": "fuzzy-guacamole",
  "version": "1.0.0",
  "description": "Comfy Frontend Orchestrator MVP scaffold",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c cyan,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node scripts/dev-server-with-db.mjs",
    "dev:server:watch": "tsx watch src/server/index.ts",
    "dev:client": "vite --config src/client/vite.config.ts",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "tsx scripts/migrate-db.mjs",
    "db:reset": "tsx scripts/reset-db.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --config src/client/vite.config.ts",
    "build:server": "tsc -p src/server/tsconfig.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p src/client/tsconfig.json --noEmit && tsc -p src/server/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:int": "node scripts/run-int-tests.mjs",
    "lint": "eslint . --max-warnings=0 && npm run lint:styles",
    "mermaid:lint": "node scripts/lint-mermaid.mjs",
    "format": "prettier --check .",
    "format:write": "prettier --write . && eslint --fix",
    "cloc": "npx cloc . --exclude-dir=coverage,dist,node_modules",
    "lint:styles": "stylelint src/client/src/**/*.{css,scss,sass}",
    "fallow": "fallow",
    "drizzle:docs:generate": "drizzle-docs generate ./src/server/db/schema.ts -d postgresql --single-file -o ./docs/DB.md",
    "drizzle:studio": "npx drizzle-kit studio",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "vitest --config vitest.storybook.config.ts",
    "i18n:extract": "cd src/client && npx i18next-cli extract --watch --sync-primary --with-types"
  },
  "keywords": [
    "comfyui",
    "fastify",
    "react",
    "vite"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/multipart": "^10.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fontsource/manrope": "^5.2.8",
    "@mantine/core": "^9.2.2",
    "@mantine/hooks": "^9.2.2",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-form": "^1.32.0",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-router": "^1.170.7",
    "@tanstack/react-router-devtools": "^1.167.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "i18next": "^26.3.1",
    "lucide-react": "^1.17.0",
    "ofetch": "^1.5.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^9.39.4",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.2",
    "@storybook/tanstack-react": "^10.4.1",
    "@tanstack/devtools-vite": "^0.7.0",
    "@tanstack/router-plugin": "^1.168.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "concurrently": "^9.2.1",
    "drizzle-docs-generator": "^0.7.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.4.1",
    "fallow": "^2.78.0",
    "globals": "^17.6.0",
    "i18next-cli": "^1.61.1",
    "jsdom": "^29.1.1",
    "mockdate": "^3.0.5",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "storybook": "^10.4.1",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
