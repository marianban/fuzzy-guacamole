{
  "name": "fuzzy-guacamole",
  "version": "1.0.0",
  "description": "Comfy Frontend Orchestrator MVP scaffold",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c cyan,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node scripts/dev-server-with-db.mjs",
    "dev:server:watch": "tsx watch src/server/index.ts",
    "dev:client": "vite --config src/client/vite.config.ts",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "tsx scripts/migrate-db.mjs",
    "db:reset": "tsx scripts/reset-db.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --config src/client/vite.config.ts",
    "build:server": "tsc -p src/server/tsconfig.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p src/client/tsconfig.json --noEmit && tsc -p src/server/tsconfig.json --noEmit",
    "test": "node scripts/run-unit-tests.mjs",
    "test:coverage": "node scripts/run-unit-tests.mjs --coverage",
    "test:watch": "vitest",
    "test:int": "node scripts/run-int-tests.mjs",
    "lint": "eslint . --max-warnings=0 && npm run lint:styles",
    "mermaid:lint": "node scripts/lint-mermaid.mjs",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "cloc": "npx cloc . --exclude-dir=coverage,dist,node_modules",
    "lint:styles": "stylelint src/client/src/**/*.{css,scss,sass}",
    "fallow": "npx fallow"
  },
  "keywords": [
    "comfyui",
    "fastify",
    "react",
    "vite"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/multipart": "^9.4.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@hookform/resolvers": "^5.2.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.4",
    "fastify-type-provider-zod": "^6.1.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "swr": "^2.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.7.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
