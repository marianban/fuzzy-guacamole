{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "verbatimModuleSyntax": true,
    "rootDir": "..",
    "outDir": "../../dist",
    "declaration": false,
    "sourceMap": true,
    "noEmit": false
  },
  "include": ["./**/*.ts", "../shared/**/*.ts"]
}
